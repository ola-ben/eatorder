# Backend environment variables
# Copy to .env and fill in real values. .env is gitignored.

# Server config
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API.
# Add your local Vite dev URL and your deployed Vercel URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://eatorder-green.vercel.app

# Supabase
# Same project URL as the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (publishable) key — used for verifying user JWTs.
SUPABASE_ANON_KEY=sb_publishable_your_publishable_key

# Service role (secret) key — server-side only, NEVER expose to the browser.
# Used to bypass RLS for admin queries.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key
